# InnaIT RBI — runtime settings (both services read this)
# Copy to /opt/rbi-web-v1/rbi.env and edit. install.sh does this for you.

SHARED_DIR=/opt/rbi-web-v1/shared
SERVER_HOST=CHANGE_ME_SERVER_IP      # this server's IP/host, used for "Open in RBI" links
BASE_PORT=8100
PORT=8100

# Admin console (CHANGE THESE)
ADMIN_PORT=8200
ADMIN_USER=admin
ADMIN_PASS=change-this-password
ADMIN_SECRET=change-this-long-random-secret

# Streamer
BITRATE=5000000
WARM_W=1600
WARM_H=900
# MAX_SESSIONS=   # optional override; blank = auto-computed from CPU/RAM
